{
	"$schema": "https://opencode.ai/config.json",
	"disabled_providers": [
		"openrouter",
		"xai"
	],
	"share": "disabled",
	"model": "ollama/gemma4:e2b",
	"small_model": "ollama/gemma4:e2b",
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://127.0.0.1:11434/v1"
			},
			"models": {
				"gemma4:e2b": {
					"name": "Gemma 4 E2B (local)"
				}
			}
		}
	},
	"compaction": {
		"auto": true,
		"prune": true,
		"reserved": 15000
	},
	"permission": {
		"edit": "ask"
	},
	"default_agent": "manual",
	"agent": {
		"manual": {
			"description": "Explicit-control primary mode.",
			"mode": "primary",
			"prompt": "{file:agents/manual.md}",
			"permission": {
				"edit": "allow",
				"question": "allow",
				"task": "deny"
			}
		},
		"auto": {
			"description": "Scoped-autonomy primary mode.",
			"mode": "primary",
			"prompt": "{file:agents/auto.md}",
			"permission": {
				"edit": "allow",
				"question": "allow",
				"task": "deny"
			}
		},
		"plan": {
			"description": "Target-read-only planning mode with active-run artifact writes.",
			"mode": "primary",
			"prompt": "{file:agents/plan.md}",
			"permission": {
				"edit": {
					"*": "deny",
					"_workspace/runs/active/**": "allow",
					"*/_workspace/runs/active/**": "allow"
				},
				"question": "allow",
				"task": "deny"
			}
		},
		"build": {
			"disable": true
		},
		"general": {
			"disable": true
		},
		"explore": {
			"disable": true
		},
		"scout": {
			"disable": true
		}
	}
}
